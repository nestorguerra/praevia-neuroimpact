# Google Cloud production profile
#
# Este perfil documenta la variante Google-first. Algunas claves requieren
# adaptacion de codigo antes de sustituir completamente el perfil RunPod/Supabase.

APP_ENV=production
APP_HOST=app.neuroimpact.praevia.ai
API_HOST=api.neuroimpact.praevia.ai
APP_PUBLIC_URL=https://app.neuroimpact.praevia.ai
API_PUBLIC_URL=https://api.neuroimpact.praevia.ai
VITE_API_PUBLIC_URL=https://api.neuroimpact.praevia.ai

# Deploy
FRONTEND_DEPLOY_PROVIDER=firebase_hosting
BACKEND_PROVIDER=google_cloud_run
GCP_PROJECT_ID=
GCP_REGION=europe-west1
GCP_ARTIFACT_REGISTRY=
GCP_BACKEND_SERVICE_NAME=praevia-neuroimpact-api
GCP_TRIBE_WORKER_SERVICE_NAME=praevia-tribe-worker

# Auth
# Opcion rapida: mantener Supabase Auth mientras se migra.
# Opcion Google-first: firebase/identity_platform requiere adaptar backend auth.
VITE_AUTH_MODE=supabase
AUTH_MODE=supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Cloud SQL PostgreSQL
PERSISTENCE_MODE=db
DATABASE_URL=postgresql://USER:PASSWORD@/neuroimpact?host=/cloudsql/GCP_PROJECT_ID:europe-west1:praevia-neuroimpact-prod
CLOUD_SQL_INSTANCE=GCP_PROJECT_ID:europe-west1:praevia-neuroimpact-prod

# Queue
QUEUE_PROVIDER=google_cloud_tasks
GCP_TASKS_QUEUE=tribe-runs
GCP_TASKS_LOCATION=europe-west1
GCP_TASKS_SERVICE_ACCOUNT=

# Storage
# Modo 1, compatible actual: Cloud Storage S3 interoperability con HMAC.
STORAGE_PROVIDER=google_cloud_storage
STORAGE_MODE=s3
S3_ENDPOINT=https://storage.googleapis.com
S3_REGION=auto
S3_BUCKET=praevia-neuroimpact-production
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_CREATE_BUCKET_IF_MISSING=false

# TRIBE GPU
GPU_PROVIDER=google_cloud_run_gpu
TRIBE_WORKER_MODE=remote_gpu
TRIBE_WORKER_ENDPOINT_URL=https://praevia-tribe-worker-REGION-PROJECT.a.run.app
TRIBE_WORKER_IMAGE=europe-west1-docker.pkg.dev/GCP_PROJECT_ID/praevia/tribe-worker:production
TRIBE_OUTPUT_BUCKET=praevia-neuroimpact-production
TRIBE_OUTPUT_PREFIX=predictions
TRIBE_MODEL_ID=facebook/tribev2
TRIBE_EXPECTED_VERTICES=20484
TRIBE_MAX_ASSET_DURATION_SECONDS=180
TRIBE_RUN_TIMEOUT_SECONDS=1800
TRIBE_RUN_POLL_SECONDS=5
TRIBE_RUN_MAX_RETRIES=2
TRIBE_GPU_EUR_PER_SECOND=0.00035
TRIBE_CALLBACK_URL=https://api.neuroimpact.praevia.ai/v1/internal/tribe/callback
TRIBE_CALLBACK_SECRET=
TRIBE_WORKER_BEARER_TOKEN=
HF_TOKEN=

# Preprocessing CPU
PREPROCESSING_WORKER_MODE=local_cpu
PREPROCESSING_TEMP_DIR=/tmp/praevia-preprocessing
WHISPER_PROVIDER=local
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=60
LLM_INTERPRETER_MODEL=gpt-5.5
LLM_WRITER_MODEL=gpt-5.5
LLM_WRITER_REASONING_EFFORT=high
LLM_PROMPT_VERSION=report-master-v0.1
LLM_JSON_MAX_RETRIES=2
LLM_INPUT_EUR_PER_1K=0
LLM_OUTPUT_EUR_PER_1K=0

# Reporting
REPORT_RENDERER_MODE=playwright
REPORT_RENDERER_TIMEOUT_SECONDS=45

# Email
EMAIL_PROVIDER=firebase_or_resend
RESEND_API_KEY=
EMAIL_FROM=PraevIA <no-reply@neuroimpact.praevia.ai>

# Security
JWT_SECRET=
SIGNED_URL_TTL_SECONDS=900
CORS_ALLOWED_ORIGINS=https://app.neuroimpact.praevia.ai
ALLOWED_HOSTS=api.neuroimpact.praevia.ai
FORCE_HTTPS=true
READINESS_TOKEN=
RETENTION_DAYS=90
MONTHLY_COST_CAP_EUR=350
MONTHLY_GPU_CAP_SECONDS=7200
STORAGE_EUR_PER_GB_MONTH=0.026
PLATFORM_EVENT_EUR=0.015

# Observability
OBSERVABILITY_PROVIDER=google_cloud_logging
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0
STRUCTURED_LOGS=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS=120
COST_ALERT_THRESHOLD_EUR=250
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
VITE_APP_ENV=production
