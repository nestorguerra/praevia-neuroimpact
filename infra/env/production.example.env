# Production
APP_ENV=production
APP_HOST=app.neuroimpact.praevia.ai
API_HOST=api.neuroimpact.praevia.ai
APP_PUBLIC_URL=https://app.neuroimpact.praevia.ai
API_PUBLIC_URL=https://api.neuroimpact.praevia.ai
VITE_API_PUBLIC_URL=https://api.neuroimpact.praevia.ai
FRONTEND_DEPLOY_PROVIDER=docker_compose
BACKEND_PROVIDER=docker_compose
GHCR_IMAGE_NAMESPACE=nestorguerra
IMAGE_TAG=production-local
CADDY_ACME_EMAIL=ops@praevia.ai
VITE_AUTH_MODE=supabase
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Supabase/Postgres
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=postgresql://USER:PASSWORD@PRODUCTION_DB_HOST:5432/neuroimpact

# Queue
QUEUE_PROVIDER=upstash_redis
REDIS_URL=

# Storage
STORAGE_PROVIDER=cloudflare_r2
STORAGE_MODE=s3
S3_ENDPOINT=https://PRODUCTION_ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=praevia-neuroimpact-production
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_CREATE_BUCKET_IF_MISSING=false

# TRIBE GPU
GPU_PROVIDER=google_cloud_run_gpu
GPU_PROVIDER_API_KEY=
RUNPOD_API_KEY=
GCP_PROJECT_ID=praevia-neuroimpact-prod
GCP_REGION=europe-west1
GCP_TASKS_QUEUE=tribe-runs
GCP_TASKS_LOCATION=europe-west1
GCP_TASKS_SERVICE_ACCOUNT=praevia-tribe-worker@praevia-neuroimpact-prod.iam.gserviceaccount.com
HF_TOKEN=
TRIBE_MODEL_ID=facebook/tribev2
MODEL_CACHE_DIR=/models/tribe
TRIBE_WORKER_MODE=remote_gpu
TRIBE_WORKER_ENDPOINT_URL=https://praevia-tribe-worker-xxxxx-ew.a.run.app
ALLOW_MOCK_WORKER_IN_PRODUCTION_GATE=false
TRIBE_WORKER_IMAGE=europe-west1-docker.pkg.dev/praevia-neuroimpact-prod/praevia/tribe-worker:production
TRIBE_OUTPUT_BUCKET=praevia-neuroimpact-production
TRIBE_OUTPUT_PREFIX=predictions
TRIBE_EXPECTED_VERTICES=20484
TRIBE_MAX_ASSET_DURATION_SECONDS=180
TRIBE_RUN_TIMEOUT_SECONDS=900
TRIBE_RUN_POLL_SECONDS=5
TRIBE_RUN_MAX_RETRIES=2
TRIBE_GPU_EUR_PER_SECOND=0.00035
TRIBE_CALLBACK_URL=https://api.neuroimpact.praevia.ai/v1/internal/tribe/callback
TRIBE_CALLBACK_SECRET=
TRIBE_WORKER_BEARER_TOKEN=

# Preprocessing CPU
PREPROCESSING_WORKER_MODE=local_cpu
PREPROCESSING_TEMP_DIR=/tmp/praevia-preprocessing
WHISPER_PROVIDER=local
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# LLM
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=60
LLM_INTERPRETER_MODEL=gpt-5.5-pro
LLM_WRITER_MODEL=gpt-5.5-thinking
LLM_WRITER_REASONING_EFFORT=high
LLM_PROMPT_VERSION=report-master-v0.1
LLM_JSON_MAX_RETRIES=2
LLM_INPUT_EUR_PER_1K=0
LLM_OUTPUT_EUR_PER_1K=0

# Server-side PDF renderer
REPORT_RENDERER_MODE=playwright
REPORT_RENDERER_TIMEOUT_SECONDS=45

# Email
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=PraevIA <no-reply@neuroimpact.praevia.ai>

# Security
AUTH_MODE=supabase
PERSISTENCE_MODE=db
JWT_SECRET=
SIGNED_URL_TTL_SECONDS=900
CORS_ALLOWED_ORIGINS=https://app.neuroimpact.praevia.ai
ALLOWED_HOSTS=api.neuroimpact.praevia.ai
FORCE_HTTPS=true
READINESS_TOKEN=
RETENTION_DAYS=90
MONTHLY_COST_CAP_EUR=350
MONTHLY_GPU_CAP_SECONDS=7200
STORAGE_EUR_PER_GB_MONTH=0.015
PLATFORM_EVENT_EUR=0.015

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0
STRUCTURED_LOGS=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS=120
COST_ALERT_THRESHOLD_EUR=250
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
VITE_APP_ENV=production
