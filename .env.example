# App
APP_ENV=local
APP_PUBLIC_URL=http://localhost:5173
API_PUBLIC_URL=http://localhost:8000
VITE_API_PUBLIC_URL=http://localhost:8000
FRONTEND_DEPLOY_PROVIDER=local
BACKEND_PROVIDER=local
VITE_AUTH_MODE=local
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Database
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
DATABASE_URL=postgresql://neuroimpact:neuroimpact@localhost:5432/neuroimpact

# Queue
QUEUE_PROVIDER=local_redis
REDIS_URL=redis://localhost:6379/0

# Storage
STORAGE_PROVIDER=minio
S3_ENDPOINT=http://localhost:9000
S3_REGION=eu-west-1
S3_BUCKET=neuroimpact-local
S3_ACCESS_KEY_ID=local
S3_SECRET_ACCESS_KEY=localpassword

# Model / ML
GPU_PROVIDER=runpod_serverless
GPU_PROVIDER_API_KEY=
RUNPOD_API_KEY=
GCP_PROJECT_ID=
GCP_REGION=europe-west1
GCP_TASKS_QUEUE=
GCP_TASKS_LOCATION=
GCP_TASKS_SERVICE_ACCOUNT=
HF_TOKEN=
TRIBE_MODEL_ID=facebook/tribev2
MODEL_CACHE_DIR=./worker/model-cache
TRIBE_WORKER_MODE=mock
TRIBE_WORKER_ENDPOINT_URL=
ALLOW_MOCK_WORKER_IN_PRODUCTION_GATE=true
TRIBE_WORKER_IMAGE=praevia/tribe-worker:local
TRIBE_OUTPUT_BUCKET=neuroimpact-local
TRIBE_OUTPUT_PREFIX=predictions
TRIBE_EXPECTED_VERTICES=20484
TRIBE_MAX_ASSET_DURATION_SECONDS=180
TRIBE_RUN_TIMEOUT_SECONDS=900
TRIBE_RUN_POLL_SECONDS=5
TRIBE_RUN_MAX_RETRIES=2
TRIBE_GPU_EUR_PER_SECOND=0.00025
TRIBE_CALLBACK_URL=http://localhost:8000/v1/internal/tribe/callback
TRIBE_CALLBACK_SECRET=change-me-tribe-callback
TRIBE_WORKER_BEARER_TOKEN=

# Preprocessing CPU
PREPROCESSING_WORKER_MODE=mock
PREPROCESSING_TEMP_DIR=/tmp/praevia-preprocessing
WHISPER_PROVIDER=local
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# LLM router
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=60
ANTHROPIC_API_KEY=
LLM_INTERPRETER_MODEL=gpt-5.5-pro
LLM_WRITER_MODEL=gpt-5.5-thinking
LLM_WRITER_REASONING_EFFORT=high
LLM_PROMPT_VERSION=report-master-v0.1
LLM_JSON_MAX_RETRIES=2
LLM_INPUT_EUR_PER_1K=0
LLM_OUTPUT_EUR_PER_1K=0
LLM_REPORT_MODEL=
LLM_REVIEW_MODEL=

# Server-side PDF renderer
REPORT_RENDERER_MODE=playwright
REPORT_RENDERER_TIMEOUT_SECONDS=45

# Email
EMAIL_PROVIDER=none
RESEND_API_KEY=
EMAIL_FROM=

# Security
AUTH_MODE=local
PERSISTENCE_MODE=memory
JWT_SECRET=change-me-local-only
SIGNED_URL_TTL_SECONDS=900
CORS_ALLOWED_ORIGINS=http://localhost:5173
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,testserver
FORCE_HTTPS=false
READINESS_TOKEN=
RETENTION_DAYS=30
MONTHLY_COST_CAP_EUR=350
MONTHLY_GPU_CAP_SECONDS=7200
STORAGE_EUR_PER_GB_MONTH=0.015
PLATFORM_EVENT_EUR=0.015

# Observability
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0
STRUCTURED_LOGS=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS=240
COST_ALERT_THRESHOLD_EUR=0
VITE_SENTRY_DSN=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
VITE_APP_ENV=local
