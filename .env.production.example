# App
APP_ENV=production
APP_PUBLIC_URL=https://app.neuroimpact.praevia.ai
API_PUBLIC_URL=https://api.neuroimpact.praevia.ai
VITE_API_PUBLIC_URL=https://api.neuroimpact.praevia.ai
APP_HOST=app.neuroimpact.praevia.ai
API_HOST=api.neuroimpact.praevia.ai
FRONTEND_DEPLOY_PROVIDER=docker_compose
BACKEND_PROVIDER=docker_compose
GHCR_IMAGE_NAMESPACE=nestorguerra
IMAGE_TAG=production-local
CADDY_ACME_EMAIL=ops@praevia.ai
VITE_AUTH_MODE=supabase
VITE_SUPABASE_URL=replace-with-production-supabase-url
VITE_SUPABASE_ANON_KEY=replace-with-production-supabase-anon-key

# Database
SUPABASE_URL=replace-with-production-supabase-url
SUPABASE_ANON_KEY=replace-with-production-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=replace-with-secret
SUPABASE_JWT_SECRET=replace-with-secret
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/neuroimpact

# Queue
REDIS_URL=redis://USER:PASSWORD@HOST:6379/0

# Storage
STORAGE_PROVIDER=cloudflare_r2
STORAGE_MODE=s3
S3_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
S3_REGION=auto
S3_BUCKET=neuroimpact-prod
S3_ACCESS_KEY_ID=replace-with-secret
S3_SECRET_ACCESS_KEY=replace-with-secret

# Model / ML
GPU_PROVIDER=runpod_serverless
GPU_PROVIDER_API_KEY=replace-with-secret
RUNPOD_API_KEY=replace-with-secret
GCP_PROJECT_ID=
GCP_REGION=europe-west1
GCP_TASKS_QUEUE=
GCP_TASKS_LOCATION=
GCP_TASKS_SERVICE_ACCOUNT=
HF_TOKEN=replace-with-secret
TRIBE_MODEL_ID=facebook/tribev2
MODEL_CACHE_DIR=/models/tribe
TRIBE_WORKER_MODE=remote_gpu
TRIBE_WORKER_ENDPOINT_URL=https://api.runpod.ai/v2/<production-endpoint-id>
ALLOW_MOCK_WORKER_IN_PRODUCTION_GATE=false
TRIBE_WORKER_IMAGE=praevia/tribe-worker:prod
TRIBE_OUTPUT_BUCKET=neuroimpact-prod
TRIBE_OUTPUT_PREFIX=predictions
TRIBE_EXPECTED_VERTICES=20484
TRIBE_MAX_ASSET_DURATION_SECONDS=180
TRIBE_RUN_TIMEOUT_SECONDS=900
TRIBE_RUN_POLL_SECONDS=5
TRIBE_RUN_MAX_RETRIES=2
TRIBE_GPU_EUR_PER_SECOND=0.00025
TRIBE_CALLBACK_URL=https://api.neuroimpact.praevia.ai/v1/internal/tribe/callback
TRIBE_CALLBACK_SECRET=replace-with-secret
TRIBE_WORKER_BEARER_TOKEN=

# LLM router
OPENAI_API_KEY=replace-with-secret
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=60
ANTHROPIC_API_KEY=replace-with-secret
LLM_INTERPRETER_MODEL=gpt-5.5-pro
LLM_WRITER_MODEL=gpt-5.5-thinking
LLM_WRITER_REASONING_EFFORT=high
LLM_PROMPT_VERSION=report-master-v0.1
LLM_JSON_MAX_RETRIES=2
LLM_INPUT_EUR_PER_1K=0
LLM_OUTPUT_EUR_PER_1K=0
LLM_REVIEW_MODEL=claude-opus-4.7

# Server-side PDF renderer
REPORT_RENDERER_MODE=playwright
REPORT_RENDERER_TIMEOUT_SECONDS=45

# Security
AUTH_MODE=supabase
PERSISTENCE_MODE=db
JWT_SECRET=replace-with-secret
SIGNED_URL_TTL_SECONDS=900
CORS_ALLOWED_ORIGINS=https://app.neuroimpact.praevia.ai
ALLOWED_HOSTS=api.neuroimpact.praevia.ai
FORCE_HTTPS=true
READINESS_TOKEN=replace-with-secret
RETENTION_DAYS=30
MONTHLY_COST_CAP_EUR=1200
MONTHLY_GPU_CAP_SECONDS=14400

# Observability
SENTRY_DSN=replace-with-secret
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0
STRUCTURED_LOGS=true
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_REQUESTS=120
COST_ALERT_THRESHOLD_EUR=250
VITE_SENTRY_DSN=replace-with-public-sentry-dsn
VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
VITE_APP_ENV=production
